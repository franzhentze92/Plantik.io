# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (OAuth redirects, Recurrente, email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google sign-in: enable in Supabase → Authentication → Providers → Google
# Add redirect URLs in Supabase → Authentication → URL Configuration:
#   - Site URL: https://plantik.io
#   - Redirect URLs: https://plantik.io/auth/callback, http://localhost:3000/auth/callback

# Order emails (Resend) — https://resend.com/api-keys
# After verifying plantik.io in Resend, set EMAIL_FROM to e.g. Plantik <info@plantik.io>
# Comma-separated extra admin emails for order notifications and dashboard access
# Built-in admins (code): admin@plantik.io, franz@nutri-tech.com.au, hentzefranz92@gmail.com
RESEND_API_KEY=
EMAIL_FROM=Plantik <info@plantik.io>
ORDER_ADMIN_EMAIL=hentzefranz92@gmail.com,franz@nutri-tech.com.au

# Recurrente — https://docs.recurrente.com/guias-espanol/comenzar/introduccion
# Llaves en Recurrente → Configuración → Llaves API
RECURRENTE_SECRET_KEY=

# Webhook signing secret (whsec_...) from Recurrente → Configuración → Webhooks
RECURRENTE_WEBHOOK_SECRET=
